# ──────────────────────────────────────
# Voice Bot Widget — Configuration
# ──────────────────────────────────────

# OpenAI API key (required for chat & optional for embeddings)
OPENAI_API_KEY=sk-your-api-key-here

# LLM model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# Server port (default: 3800)
PORT=3800

# Knowledge-base directory (default: ./server/knowledge-base)
KB_DIR=./server/knowledge-base

# System prompt (customises the bot personality)
SYSTEM_PROMPT=You are a friendly and helpful voice assistant. Answer questions concisely and conversationally. Use the provided knowledge base context when relevant. Keep responses under 3 sentences unless the user asks for detail.

# ──────────────────────────────────────
# Groww Trading API (optional)
# ──────────────────────────────────────
# Option 1: Paste your access token directly (generate from Groww dashboard)
GROWW_ACCESS_TOKEN=

# Option 2: Auto-generate token using API Key + Secret
#   Get these from https://groww.in/trade-api/api-keys
GROWW_API_KEY=
GROWW_API_SECRET=
